# ─────────────────────────────────────────────────────────────
#  GlowCRM — приклад конфігурації. Скопіюйте у файл `.env`
#  Windows:  copy .env.example .env
# ─────────────────────────────────────────────────────────────

# 🔑 Токен Telegram-бота (отримайте у @BotFather). ОБОВʼЯЗКОВО.
#    НІКОЛИ не комітьте справжній токен — він має бути лише у файлі .env!
BOT_TOKEN=PUT-YOUR-TELEGRAM-BOT-TOKEN-HERE

# 👑 Адміністратори, що отримають адмін-панель прямо в боті.
#    Можна вказати ОДНОГО або БАГАТЬОХ через кому.
#    За username (без @) та/або за числовим Telegram ID.
ADMIN_USERNAMES=your_username
ADMIN_IDS=

# 🏷️ Назва студії (показується клієнтам)
BUSINESS_NAME=GlowStudio
